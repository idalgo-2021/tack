/neurotests/
*prompt*
*.prompts/
*skills*/
*.md.tmp
.agents/
skills-lock.json
plans/
REVIEW*

# ==========================================
# Стандартный .gitignore для Flutter и Dart
# ==========================================

# Логи и временные файлы компиляции Dart
.dart_tool/
.packages
.pub-cache/
.pub/
build/

# Файлы конфигурации веб-сборки (если используете)
.web_plugins/

# Символические ссылки на плагины Flutter
.flutter-plugins
.flutter-plugins-dependencies
.generated_development_ids

# Файлы плагина Hive (базы данных) и его генераторов
*.g.dart
*.hive

# Настройки сред разработки (IDE)
# IntelliJ / Android Studio
.idea/
*.iml
*.ipr
*.iws

# Visual Studio Code
.vscode/

# Специфичные файлы операционных систем
.DS_Store
Thumbs.db

# Конфигурационные файлы локального окружения (токены, ключи)
.env
.env.*

# Android keystore и ключи подписи
/android/key.properties
**/keystore.jks